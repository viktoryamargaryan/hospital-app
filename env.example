# ============================================================
# ENVIRONMENT VARIABLES CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to GitHub!
# Add .env to your .gitignore file
# ============================================================

# ─── FLASK CONFIGURATION ───
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-super-secret-key-change-this-in-production

# ─── LOCAL DEVELOPMENT (SQL Server on your computer) ───
# Uncomment these for local development only
# DATABASE_SERVER=.\SQLEXPRESS
# DATABASE_NAME=HospitalDB
# DATABASE_USER=
# DATABASE_PASSWORD=

# ─── PRODUCTION (Azure SQL Database) ───
# Fill these in with your Azure SQL credentials
DATABASE_SERVER=your-server.database.windows.net
DATABASE_NAME=HospitalDB
DATABASE_USER=adminuser@your-server
DATABASE_PASSWORD=YourSecurePassword123!

# ─── SERVER CONFIGURATION ───
PORT=5000
ALLOWED_ORIGINS=http://localhost:5000

# ============================================================
# HOW TO GET THESE VALUES:
# ============================================================
# 
# DATABASE_SERVER:
#   - Local: .\SQLEXPRESS (Windows only)
#   - Azure: Go to Azure Portal → SQL Servers → Overview
#     Copy the "Server name" (ends with .database.windows.net)
#
# DATABASE_NAME:
#   - Local or Azure: HospitalDB
#
# DATABASE_USER:
#   - Local: Leave empty (uses Windows Auth)
#   - Azure: Admin username you created (e.g., adminuser@servername)
#
# DATABASE_PASSWORD:
#   - Local: Leave empty (uses Windows Auth)
#   - Azure: Password you set during SQL Server creation
#
# SECRET_KEY:
#   - Generate a random string: python -c "import secrets; print(secrets.token_hex(32))"
#
# ============================================================
